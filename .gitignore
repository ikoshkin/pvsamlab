# Ignore unnecessary files
.claude/
__pycache__/
*.pyc
*.pyo
*.pyd
.env
.venv
.envrc
.idea/
.vscode/
.DS_Store
pvsamlab/data/tmp/*
pvsamlab/data/weather_files/*
secrets.env
examples/secrets.env

# Generated outputs in per-tool outputs/ subfolders
examples/*/outputs/*/
examples/*/outputs/*.csv
examples/*/outputs/*.png
examples/*/outputs/*.log
examples/*/outputs/*.txt
examples/*/outputs/*.pdf

# Keep outputs/ folders in git (gitkeep files are tracked)
!examples/*/outputs/.gitkeep

# Note: DAMPriceExample.csv in pvsamlab/data/ IS committed (source data)
pvsamlab/data/tmp/
pvsamlab/data/weather_files/

