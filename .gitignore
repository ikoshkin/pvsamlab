# Ignore unnecessary files
.claude/
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.env
.venv
.envrc
.idea/
.vscode/
.DS_Store
pvsamlab/data/tmp/*
pvsamlab/data/weather_files/*
secrets.env
examples/secrets.env

# Generated outputs in per-tool outputs/ subfolders
examples/*/outputs/*/
examples/*/outputs/*.csv
examples/*/outputs/*.png
examples/*/outputs/*.log
examples/*/outputs/*.txt
examples/*/outputs/*.pdf

# Keep outputs/ folders in git (gitkeep files are tracked)
!examples/*/outputs/.gitkeep

# Note: DAMPriceExample.csv in pvsamlab/data/ IS committed (source data)
pvsamlab/data/tmp/
pvsamlab/data/weather_files/
**/weather_files/

# Build artifacts
pvsamlab.egg-info/
*.egg-info/

# Secrets (belt-and-suspenders — also listed above individually)
**/secrets.env
**/.env

# Internal planning / audit docs
AUDIT.md
PROGRESS.md
BESS_DESIGN.md

# Generated data files
df.csv
string_sizing_results.csv
pvsamlab/data/untitled_pvsamv1.json
**/untitled_*.json

# Executed notebook snapshots
examples/bess_sandbox/bess_sandbox_executed.ipynb
